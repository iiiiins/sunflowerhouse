---
const files = await Astro.glob('../content/gallery/*.md');
const slots = files
  .map(f => f.frontmatter)
  .sort((a, b) => a.order - b.order);

const gridClasses = ['g1','g2','g3','g4','g5','g6','g7'];
---
<section class="gallery-section" id="gallery" aria-label="Photo Gallery">
  <div class="gallery-header inner">
    <span class="tag">— Photo Tour</span>
    <h2 class="section-title">Inside the<br><em>House</em></h2>
  </div>
  <div class="gal-grid">
    {slots.slice(0, 7).map((s, i) => (
      <div class={`gal-item ${gridClasses[i]}`}>
        <img src={s.photo} alt={s.caption} />
        <div class="gal-caption">{s.caption}</div>
      </div>
    ))}
  </div>
</section>
