---
---
<section class="pricing" id="pricing">
  <div class="inner">
    <span class="tag">— Book Your Bootcamp</span>
    <h2 class="section-title">Make a<br><em>Reservation</em></h2>
    <div class="price-grid">
      <div class="price-card">
        <div class="price-dur">Hourly PC Rental</div>
        <div class="price-name">Short Stay</div>
        <div class="price-amt"><span class="cur">€</span>15<span class="per"> / 3h</span></div>
        <div class="price-note">Per PC station · Minimum 3 hours</div>
        <div class="price-div" aria-hidden="true"></div>
        <ul class="price-feats">
          <li>Rent PCs by the hour</li>
          <li>€15 per station for 3 hours</li>
          <li>Training room access</li>
          <li>High-speed internet</li>
          <li>Flexible time slots</li>
        </ul>
        <div class="price-cta"><a href="#contact" class="btn-ghost">Book Hours</a></div>
      </div>
      <div class="price-card featured">
        <div class="price-hot" aria-label="Most popular">Most Popular</div>
        <div class="price-dur">Daily Bootcamp Rental</div>
        <div class="price-name">Standard Bootcamp</div>
        <div class="price-amt"><span class="cur">€</span>150<span class="per"> / day</span></div>
        <div class="price-note">6 PCs included · Full day access</div>
        <div class="price-div" aria-hidden="true"></div>
        <ul class="price-feats">
          <li>6 gaming stations</li>
          <li>€150 flat rate per day</li>
          <li>Full training room</li>
          <li>Gym &amp; pool access</li>
          <li>House manager on-site</li>
          <li>Flexible scheduling</li>
        </ul>
        <div class="price-cta"><a href="#contact" class="btn-yellow">Book Now</a></div>
      </div>
      <div class="price-card">
        <div class="price-dur">Full Package</div>
        <div class="price-name">Complete Pack</div>
        <div class="price-tbd">Custom</div>
        <div class="price-note">PCs + Accommodation + Food · Price by email</div>
        <div class="price-div" aria-hidden="true"></div>
        <ul class="price-feats">
          <li>All 20 gaming stations</li>
          <li>Full house — 13 bedrooms</li>
          <li>Meals &amp; catering</li>
          <li>Gym, pool &amp; jacuzzi</li>
          <li>House manager</li>
          <li>Fully tailored</li>
        </ul>
        <div class="price-cta"><a href="#contact" class="btn-ghost">Get a Quote</a></div>
      </div>
    </div>
    <div style="margin-top:24px">
      <div style="font-size:11px;letter-spacing:0.22em;text-transform:uppercase;color:var(--yellow);margin-bottom:16px;padding-top:8px">— Also Available For</div>
      <div class="events-row">
        <a href="#contact" class="event-card">
          <div class="event-icon" aria-hidden="true">🎂</div>
          <div class="event-name">Birthdays</div>
          <div class="event-desc">Celebrate in a unique gaming environment</div>
        </a>
        <a href="#contact" class="event-card">
          <div class="event-icon" aria-hidden="true">🎉</div>
          <div class="event-name">Parties</div>
          <div class="event-desc">Private parties with world-class setups</div>
        </a>
        <a href="#contact" class="event-card">
          <div class="event-icon" aria-hidden="true">🏆</div>
          <div class="event-name">Events</div>
          <div class="event-desc">LAN events, tournaments, corporate gaming</div>
        </a>
        <a href="#contact" class="event-card">
          <div class="event-icon" aria-hidden="true">📸</div>
          <div class="event-name">Photoshoots</div>
          <div class="event-desc">Professional esports &amp; lifestyle content</div>
        </a>
        <a href="#contact" class="event-card custom-card">
          <div class="event-icon" aria-hidden="true">⚡</div>
          <div class="event-name">Custom</div>
          <div class="event-desc">Have something else in mind? Let's talk</div>
        </a>
      </div>
    </div>
  </div>
</section>
