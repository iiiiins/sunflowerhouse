---
---
<section class="specs" id="specs" aria-label="Hardware Specs">
  <div class="specs-inner">
    <span class="tag">— Hardware</span>
    <h2 class="section-title">Training<br><em>Room</em></h2>
    <div class="specs-top">
      <div class="pc-visual" aria-hidden="true">
        <img src="/images/specs-pc.webp" alt="" style="object-fit:contain;background:#000;padding:20px" />
        <div class="pc-visual-overlay"></div>
        <div class="pc-visual-label">
          <div class="pc-visual-tag">— Pro Level</div>
          <div class="pc-visual-title">20 Pro Rigs</div>
        </div>
      </div>
      <div class="hw-card">
        <div class="hw-title">Hardware Specs</div>
        <div class="hw-subtitle">Per Workstation · 20 Identical Builds</div>
        <div class="hw-row">
          <div class="hw-lbl">Processor</div>
          <div class="hw-val">AMD Ryzen 7 9800X3D 8-Core 5 GHz</div>
        </div>
        <div class="hw-row">
          <div class="hw-lbl">Memory</div>
          <div class="hw-val">Corsair Vengeance RGB DDR5 32 GB 6000 MHz</div>
        </div>
        <div class="hw-row">
          <div class="hw-lbl">Graphics Card</div>
          <div class="hw-val">NVIDIA GeForce RTX 5080 16 GB GDDR7</div>
        </div>
        <div class="hw-row">
          <div class="hw-lbl">Monitor</div>
          <div class="hw-val">BenQ Zowie XL2566K 24.5" — 360 Hz</div>
        </div>
        <div class="hw-badge">
          <div class="hw-badge-n">20</div>
          <div class="hw-badge-l">Identical<br>Workstations</div>
        </div>
      </div>
    </div>
    <div class="specs-grid" aria-label="Key hardware figures">
      <div class="spec-block">
        <div class="spec-n">360<span class="spec-u">Hz</span></div>
        <div class="spec-l">Monitor Rate</div>
      </div>
      <div class="spec-block">
        <div class="spec-n">XL</div>
        <div class="spec-l">Chair Size</div>
        <div class="spec-s">Secretlab Titan</div>
      </div>
      <div class="spec-block">
        <div class="spec-n">10<span class="spec-u">Gb</span></div>
        <div class="spec-l">Internet Line</div>
      </div>
      <div class="spec-block">
        <div class="spec-n" style="font-size:30px" aria-hidden="true">📷</div>
        <div class="spec-l">Webcam</div>
        <div class="spec-s">Razer Kiyo</div>
      </div>
    </div>
  </div>
</section>
