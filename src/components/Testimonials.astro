---
const files = await Astro.glob('../content/testimonials/*.md');
const testimonials = files.map(f => f.frontmatter);
---
<section class="testimonials" id="testimonials" aria-label="Testimonials">
  <div class="inner">
    <span class="tag">— Trusted by Professionals</span>
    <h2 class="section-title">What Pros<br><em>Say</em></h2>
    <div class="testi-grid">
      {testimonials.map(t => (
        <article class="testi-card">
          <div class="testi-qmark" aria-hidden="true">"</div>
          <div class="testi-stars" aria-label="5 stars">★★★★★</div>
          <p class="testi-q">"{t.quote}"</p>
          <div class="testi-author">
            <div class="testi-av" aria-hidden="true">{t.initial}</div>
            <div>
              <div class="testi-name">{t.name}</div>
              <div class="testi-role">{t.role}</div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
