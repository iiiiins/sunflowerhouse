  <div class="modal">
    <button class="modal-close" aria-label="Close modal">✕ CLOSE</button>
    <div class="m-body">
      <div class="m-section"><div class="m-section-label">👕 Laundry Service</div></div>
      <img class="m-img-full" src="/images/modal-laundry.jpeg" alt="Laundry" />
      <div class="m-specs">
        <div class="m-spec"><div class="m-spec-label">Machines</div><div class="m-spec-val">Wash + Dry</div></div>
        <div class="m-spec"><div class="m-spec-label">Service</div><div class="m-spec-val">Daily</div></div>
        <div class="m-spec"><div class="m-spec-label">Included</div><div class="m-spec-val">All packages</div></div>
      </div>
    </div>
