    <button class="modal-close" aria-label="Close modal">✕ CLOSE</button>
    <div class="m-body">
      <div class="m-section"><div class="m-section-label">🏊 Indoor Pool</div></div>
      <img class="m-img-full" src="/images/modal-pool.jpeg" alt="Indoor Pool" />
      <div class="m-specs">
        <div class="m-spec"><div class="m-spec-label">Dimensions</div><div class="m-spec-val">8 m × 3 m</div></div>
        <div class="m-spec"><div class="m-spec-label">Depth</div><div class="m-spec-val">2.3 m</div></div>
        <div class="m-spec"><div class="m-spec-label">Type</div><div class="m-spec-val">Indoor / Heated</div></div>
      </div>
      <div class="m-section"><div class="m-section-label">💪 Gym</div></div>
      <div class="m-img-grid">
        <img src="/images/modal-gym-1.jpeg" alt="Gym weights" />
        <img src="/images/modal-gym-2.jpeg" alt="Gym equipment" />
      </div>
      <div class="m-specs">
        <div class="m-spec"><div class="m-spec-label">Equipment</div><div class="m-spec-val">Free Weights</div></div>
        <div class="m-spec"><div class="m-spec-label">Equipment</div><div class="m-spec-val">Barbells</div></div>
        <div class="m-spec"><div class="m-spec-label">Equipment</div><div class="m-spec-val">Cable Machines</div></div>
      </div>
      <div class="m-section"><div class="m-section-label">♨️ Jacuzzi</div></div>
      <img class="m-img-full" src="/images/modal-jacuzzi.jpeg" alt="Jacuzzi" />
    </div>
  </div>
</div>

<div class="modal-backdrop" id="modal-outside" role="dialog" aria-modal="true" aria-label="Outdoor Space">
  <div class="modal">
    <button class="modal-close" aria-label="Close modal">✕ CLOSE</button>
    <div class="m-body">
      <div class="m-section"><div class="m-section-label">🌿 Gardens</div></div>
      <img class="m-img-full" src="/images/modal-gardens-full.jpeg" alt="Gardens" />
      <div class="m-section"><div class="m-section-label">🪵 Patio</div></div>
      <div class="m-img-grid">
        <img src="/images/modal-patio-1.jpeg" alt="Patio" />
        <img src="/images/modal-patio-2.jpeg" alt="Patio" />
      </div>
      <div class="m-section"><div class="m-section-label">🌅 Deck</div></div>
      <img class="m-img-full" src="/images/modal-deck.jpeg" alt="Deck" />
    </div>
