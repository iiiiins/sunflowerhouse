      <div class="m-specs" style="grid-template-columns:1fr 1fr">
        <div class="m-spec"><div class="m-spec-label">Bed</div><div class="m-spec-val">Double</div></div>
        <div class="m-spec"><div class="m-spec-label">Bathroom</div><div class="m-spec-val">Private · 2 rooms</div></div>
