</div>

<div class="modal-backdrop" id="modal-parking" role="dialog" aria-modal="true" aria-label="Parking">
  <div class="modal">
    <button class="modal-close" aria-label="Close modal">✕ CLOSE</button>
    <div class="m-body">
      <div class="m-section"><div class="m-section-label">🚗 Car Parking</div></div>
      <img class="m-img-full" src="/images/modal-parking.jpeg" alt="Car Parking" />
      <div class="m-specs">
        <div class="m-spec"><div class="m-spec-label">Spaces</div><div class="m-spec-val">Multiple</div></div>
        <div class="m-spec"><div class="m-spec-label">Security</div><div class="m-spec-val">24/7 Cameras</div></div>
        <div class="m-spec"><div class="m-spec-label">Access</div><div class="m-spec-val">Included</div></div>
      </div>
      <div class="m-section"><div class="m-section-label">🛞 Driver Service</div></div>
      <img class="m-img-full" src="/images/modal-driver.jpeg" alt="Driver Service" />
