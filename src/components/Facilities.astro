      <div class="m-section"><div class="m-section-label">🍳 Kitchen 2 — Secondary</div></div>
      <img class="m-img-full" src="/images/modal-kitchen-2.jpeg" alt="Kitchen 2" />
      <div class="m-specs">
        <div class="m-spec"><div class="m-spec-label">Chef</div><div class="m-spec-val">On-site</div></div>
        <div class="m-spec"><div class="m-spec-label">Meals</div><div class="m-spec-val">3× per day</div></div>
        <div class="m-spec"><div class="m-spec-label">Diet</div><div class="m-spec-val">Customisable</div></div>
      </div>
    </div>
  </div>
</div>

<div class="modal-backdrop" id="modal-bedrooms" role="dialog" aria-modal="true" aria-label="Bedrooms">
  <div class="modal">
    <button class="modal-close" aria-label="Close modal">✕ CLOSE</button>
    <div class="m-body">
      <div class="m-section"><div class="m-section-label">🛏️ Double Room with Private WC</div></div>
      <div class="m-img-grid">
        <img src="/images/modal-bedroom-double-wc-1.jpeg" alt="Double room with WC" />
        <img src="/images/modal-bedroom-double-wc-2.jpeg" alt="Double room with WC" />
