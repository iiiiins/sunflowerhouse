        <img src="/images/modal-bedroom-single-wc-2.jpeg" alt="Single room with WC" />
      </div>
      <div class="m-specs" style="grid-template-columns:1fr 1fr">
        <div class="m-spec"><div class="m-spec-label">Bed</div><div class="m-spec-val">Single</div></div>
        <div class="m-spec"><div class="m-spec-label">Bathroom</div><div class="m-spec-val">Private · 4 rooms</div></div>
      </div>
      <div class="m-section"><div class="m-section-label">🛏️ Single Room with Shared WC</div></div>
      <div class="m-img-grid">
        <img src="/images/modal-bedroom-single-shared-1.jpeg" alt="Single room shared WC" />
        <img src="/images/modal-bedroom-single-shared-2.jpeg" alt="Single room shared WC" />
      </div>
      <div class="m-specs" style="grid-template-columns:1fr 1fr">
