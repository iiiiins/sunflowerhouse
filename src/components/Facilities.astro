---
import imgs from '../content/images/site-images.json';
const facilities = [
  { id: 'training', icon: '🖥️', name: 'Training Rooms', hint: '3 rooms · 20 PCs',       size: 'fac-big',   img: imgs.fac_training },
  { id: 'pool',     icon: '🏊', name: 'Pool & Gym',     hint: 'Indoor heated pool',       size: 'fac-big',   img: imgs.fac_pool },
  { id: 'bedrooms', icon: '🛏️', name: 'Bedrooms',       hint: '13 rooms · 4 types',      size: 'fac-small', img: imgs.fac_bedrooms },
  { id: 'kitchen',  icon: '🍳', name: 'Kitchen',        hint: 'Chef on-site',              size: 'fac-small', img: imgs.fac_kitchen },
  { id: 'outside',  icon: '🌿', name: 'Outdoor Space',  hint: 'Gardens · Patio · Deck',   size: 'fac-small', img: imgs.fac_outside },
  { id: 'lounge',   icon: '🎮', name: 'Lounge',         hint: 'PS5 · Ping Pong',           size: 'fac-small', img: imgs.fac_lounge },
  { id: 'laundry',  icon: '👕', name: 'Laundry',        hint: 'Daily service',              size: 'fac-small', img: imgs.fac_laundry },
  { id: 'parking',  icon: '🚗', name: 'Parking',        hint: 'Secure · Driver service',   size: 'fac-small', img: imgs.fac_parking },
];
---
<section class="facilities" id="facilities">
  <div class="inner">
    <span class="tag">— Amenities</span>
    <h2 class="section-title">World-Class<br><em>Facilities</em></h2>
  </div>
  <div style="max-width:1280px;margin:0 auto;padding:0 60px">
    <div class="fac-grid">
      {facilities.map(f => (
        <div
          class={`fac-card ${f.size}`}
          role="button"
          tabindex="0"
          aria-haspopup="dialog"
          aria-label={`View ${f.name} details`}
          data-modal={f.id}
        >
          <img src={f.img} alt="" aria-hidden="true" />
          <div class="fac-overlay">
            <div class="fac-icon" aria-hidden="true">{f.icon}</div>
            <div class="fac-name">{f.name}</div>
            <div class="fac-hint">{f.hint} — View details</div>
          </div>
          <div class="fac-bar" aria-hidden="true"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- MODALS -->
<div class="modal-backdrop" id="modal-training" role="dialog" aria-modal="true" aria-label="Training Rooms">
  <div class="modal">
    <button class="modal-close" aria-label="Close modal">✕ CLOSE</button>
    <div class="m-tabs" role="tablist">
      <button class="m-tab active" role="tab" aria-selected="true"  data-tab="training-room1">Room 1</button>
      <button class="m-tab"        role="tab" aria-selected="false" data-tab="training-room2">Room 2</button>
      <button class="m-tab"        role="tab" aria-selected="false" data-tab="training-room3">Room 3 — Analyst</button>
      <button class="m-tab"        role="tab" aria-selected="false" data-tab="training-specs">PC Specs</button>
    </div>
    <div class="m-body">
      <div class="m-panel active" id="training-room1" role="tabpanel">
        <div class="m-section"><div class="m-section-label">🖥️ Training Room 1</div></div>
        <img class="m-img-full" src="/images/modal-training-room1.jpeg" alt="Training Room 1" style="object-position:center top" />
        <div class="m-specs">
          <div class="m-spec"><div class="m-spec-label">Stations</div><div class="m-spec-val">8 PCs</div></div>
          <div class="m-spec"><div class="m-spec-label">Format</div><div class="m-spec-val">Full Stage</div></div>
          <div class="m-spec"><div class="m-spec-label">Monitor</div><div class="m-spec-val">360 Hz</div></div>
        </div>
      </div>
      <div class="m-panel" id="training-room2" role="tabpanel">
        <div class="m-section"><div class="m-section-label">🖥️ Training Room 2</div></div>
        <img class="m-img-full" src="/images/modal-training-room2.jpeg" alt="Training Room 2" />
        <div class="m-specs">
          <div class="m-spec"><div class="m-spec-label">Stations</div><div class="m-spec-val">6 PCs</div></div>
          <div class="m-spec"><div class="m-spec-label">Format</div><div class="m-spec-val">Scrim Format</div></div>
          <div class="m-spec"><div class="m-spec-label">Monitor</div><div class="m-spec-val">360 Hz</div></div>
        </div>
      </div>
      <div class="m-panel" id="training-room3" role="tabpanel">
        <div class="m-section"><div class="m-section-label">🖥️ Training Room 3 — Analyst</div></div>
        <img class="m-img-full" src="/images/modal-training-room3.jpeg" alt="Training Room 3 — Analyst" style="object-position:center top" />
        <div class="m-specs">
          <div class="m-spec"><div class="m-spec-label">Stations</div><div class="m-spec-val">4 PCs</div></div>
          <div class="m-spec"><div class="m-spec-label">Use</div><div class="m-spec-val">VOD / Analyst</div></div>
          <div class="m-spec"><div class="m-spec-label">Monitor</div><div class="m-spec-val">360 Hz</div></div>
        </div>
      </div>
      <div class="m-panel" id="training-specs" role="tabpanel">
        <div class="m-section"><div class="m-section-label">⚙️ PC Specs — All 20 Rigs</div></div>
        <img class="m-img-full" src="/images/modal-training-specs.webp" alt="PC Setup" style="object-fit:contain;background:#000;height:280px;padding:30px" />
        <div class="m-specs" style="grid-template-columns:1fr 1fr">
          <div class="m-spec"><div class="m-spec-label">Processor</div><div class="m-spec-val">AMD Ryzen 7 9800X3D</div><div class="m-spec-sub">8-Core 5 GHz</div></div>
          <div class="m-spec"><div class="m-spec-label">Graphics</div><div class="m-spec-val">NVIDIA RTX 5080</div><div class="m-spec-sub">16 GB GDDR7</div></div>
          <div class="m-spec"><div class="m-spec-label">Memory</div><div class="m-spec-val">Corsair DDR5 32 GB</div><div class="m-spec-sub">6000 MHz</div></div>
          <div class="m-spec"><div class="m-spec-label">Monitor</div><div class="m-spec-val">BenQ Zowie 24.5"</div><div class="m-spec-sub">360 Hz XL2566K</div></div>
          <div class="m-spec"><div class="m-spec-label">Chair</div><div class="m-spec-val">Secretlab Titan XL</div><div class="m-spec-sub">Electric Table</div></div>
          <div class="m-spec"><div class="m-spec-label">Internet</div><div class="m-spec-val">10 Gbps</div><div class="m-spec-sub">Razer Kiyo Webcam</div></div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal-backdrop" id="modal-pool" role="dialog" aria-modal="true" aria-label="Pool and Gym">
