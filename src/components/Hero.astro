---
import settings from '../content/settings/general.json';
---
<section class="hero" id="home" aria-label="Hero">
  <div class="hero-bg" aria-hidden="true">
    <img src="/images/gallery-g1-exterior.jpeg" alt="" />
  </div>
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="hero-badge" aria-hidden="true">
    <span class="hero-dot"></span>{settings.hero_badge}
  </div>
  <h1>
    <span class="line-white">THE ULTIMATE</span>
    <span class="line-yellow">ESPORTS</span>
    <span class="line-outline">BOOTCAMP</span>
  </h1>
  <p class="hero-desc">{settings.hero_desc}</p>
  <div class="hero-actions">
    <a href="#contact" class="btn-yellow">Request a Booking</a>
    <a href="#gallery" class="btn-ghost">Explore the House</a>
  </div>
  <div class="hero-stats" aria-hidden="true">
    <div class="stat">
      <div class="stat-n">850<span style="font-size:24px;color:var(--yellow-dim)">m²</span></div>
      <div class="stat-l">Property Size</div>
    </div>
    <div class="stat">
      <div class="stat-n">20</div>
      <div class="stat-l">Gaming PCs</div>
    </div>
    <div class="stat">
      <div class="stat-n">13</div>
      <div class="stat-l">Bedrooms</div>
    </div>
  </div>
  <div class="hero-scroll" aria-hidden="true">
    <span>Scroll</span>
    <svg width="12" height="18" viewBox="0 0 12 18" fill="none" aria-hidden="true">
      <rect x="0.75" y="0.75" width="10.5" height="16.5" rx="5.25" stroke="#999" stroke-width="1.5"/>
      <circle cx="6" cy="5.5" r="1.75" fill="#999"/>
    </svg>
  </div>
</section>
